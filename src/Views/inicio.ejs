<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inicio</title>
</head>
<body>

<div class="layout">

    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

    <!-- Perfil -->
    <div class="left">
        <%- include('partials/profileInfo', {
            nombre: nombre,
            apellido: apellido,
            usuario: usuario,
            f_nacimiento: f_nacimiento,
            correo: correo,
            genero: genero
        }) %>
    </div>

    <!-- Tareas -->
    <div class="right">

        <%- include('partials/ModalForm',{
            tituloPagina: "Añadir Nueva Tarea",
            action: '/tarea/crear',
            tarea: null,
            categorias: categorias
        }) %>

        <div class="tareas-section">
            <% tareas.forEach(tarea => { %>
                <%- include('partials/tareaInfo',{
                    id: tarea.id,
                    estado: tarea.estado,
                    titulo: tarea.titulo,
                    categoria: tarea.categoria,
                    created_at: tarea.created_at,
                    contenido: tarea.contenido,
                    categorias: categorias,
                    tarea:tarea
                }) %>
            <% }); %>
            <% if (!tareas) {%>
                <p>No tienes tareas registradas en tu sesión </p>
            <% }%>
        </div>

    </div>

</div>
</body>
</html>

<style>
body {
    margin: 0;
    background: #f4f6f9;
    font-family: Arial, sans-serif;
}

/* Layout principal */
.layout {
    display: grid;
    grid-template-columns: 220px 300px 1fr;
    min-height: 100vh;
}

.sidebar{
    background:#1e293b;
    color:white;
    padding:20px;

    display:flex;
    flex-direction:column;
    justify-content:space-between;
}

.sidebar ul{
    list-style:none;
    padding:0;
}

.sidebar li{
    margin:15px 0;
}

.sidebar a{
    color:white;
    text-decoration:none;
}

.sidebar a:hover{
    color:#38bdf8;
}

/* Logout */
.sidebar-bottom{
    margin-top:auto;
}

.logout{
    display:block;
    padding:10px;
    border-top:1px solid rgba(255,255,255,0.2);
}

/* Columna perfil */
.left{
    padding:25px;
    background:white;
}

/* Columna tareas */
.right{
    padding:25px;
    display:flex;
    flex-direction:column;
    gap:20px;
}

/* Lista de tareas */
.tareas-section{
    display:flex;
    flex-direction:column;
    gap:15px;
}
</style>


