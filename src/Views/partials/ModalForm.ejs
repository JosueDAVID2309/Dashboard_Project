<% if(tarea) {%>
    <button class="btn edit-button" type="button" onclick="document.getElementById('modalTarea-<%= tarea.id %>').style.display='block'" >
        Editar
    </button>
    <button class="btn delete-button" type="button" onclick="document.getElementById('modalEliminar-<%= tarea.id %>').style.display='block'">
        Eliminar
    </button>
<% }else{%>
    <button class="btn create-button" onclick="document.getElementById('modalTarea').style.display='block'" >Nueva Tarea</button>
<% }%>

<div id="<%= tarea ? 'modalTarea-'+tarea.id : 'modalTarea'%>" class="modal">
    <div class="modal-contenido">
        <span class="cerrar">&times;</span>

        <h1><%= tituloPagina %></h1>

        <div class="postear">
        <form action="<%= action %>" method="POST">
            <input type="text" name="titulo" placeholder="Titulo" value="<%= tarea ? tarea.titulo : '' %>" required >
            <select name="categoria" required>
                <% categorias.forEach(categoria => { %>
                    <option value="<%= categoria.id %>"
                        <% if(tarea && tarea.categoria === categoria.nombre){ %>
                            selected
                        <% } %> 
                        >
                        <%= categoria.nombre %>
                    </option>
                <% }) %>
            </select>
            <textarea name="contenido" rows="5" cols="40" placeholder="Descripción" required><%= tarea ? tarea.contenido : '' %></textarea>
            <input class="btn action-button" type="submit" value="<%= tarea ? 'Actualizar tarea' : 'Crear tarea' %>">
        </form>
        </div>
    </div>
</div>

<% if(tarea){ %>

<div id="modalEliminar-<%= tarea.id %>" class="modal">
    <div class="modal-contenido">
        <span class="cerrar">&times;</span>

        <h2>¿Seguro que quieres borrar esta tarea?</h2>
        <strong><%= tarea.titulo %>: </strong> 
        <p><%= tarea.contenido %></p>

        <form action="/tarea/delete/<%= tarea.id %>" method="POST">
            <button class="btn cancel-button" type="button" class="cancelar">Cancelar</button>
            <button class="btn delete-button" type="submit">Eliminar</button>
        </form>
    </div>
</div>
<% } %>

<script>

document.querySelectorAll(".cerrar").forEach(btn => {

    btn.onclick = () => {
        const modal = btn.closest(".modal")
        modal.style.display = "none"
    }

})

document.querySelectorAll(".cancelar").forEach(btn => {

    btn.onclick = () => {
        const modal = btn.closest(".modal")
        modal.style.display = "none"
    }

})

window.onclick = (e) => {
    if(e.target.classList.contains("modal")){
        e.target.style.display = "none"
    }
}

</script>

<style>
.modal{
    display:none;
    position:fixed;
    z-index:10;
    left:0;
    top:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.5);
}

.modal-contenido{
    background:white;
    width:400px;
    margin:10% auto;
    padding:20px;
    border-radius:8px;
    animation: aparecer 0.2s ease;
}

.btn{
    padding: 10px 16px;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    color: white;
    transition: all 0.2s ease;
}

.create-button{
    background-color: #7ed957;
}

.create-button:hover{
    background-color: #6ac447;
}

.edit-button{
    background-color: #4fc3f7;
}

.edit-button:hover{
    background-color: #3bb0e6;
}

.delete-button{
    background-color: #f44336;
}

.delete-button:hover{
    background-color: #d7372b;
}

.cancel-button{
    background-color: #469cff;
}

.cancel-button:hover{
    background-color: #5aa7fff3;
}

.action-button{
    background-color: #469cff;
}

.action-button:hover{
    background-color: #5aa7fff3;
}

@keyframes aparecer{
    from{
        transform:scale(0.9);
        opacity:0;
    }
    to{
        transform:scale(1);
        opacity:1;
    }
}

.cerrar{
    float:right;
    font-size:24px;
    cursor:pointer;
}
</style>